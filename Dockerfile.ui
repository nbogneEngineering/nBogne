# =============================================================================
# nBogne Dashboard Dockerfile
# =============================================================================
# Web UI for health workers to send data and monitor queue.
# =============================================================================

FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY requirements.txt .
COPY ui/requirements.txt ./ui/
RUN pip install --no-cache-dir -r requirements.txt -r ui/requirements.txt

# Copy application code
COPY nbogne/ ./nbogne/
COPY ui/ ./ui/

# Expose Flask port
EXPOSE 8501

# Run with gunicorn
CMD ["gunicorn", "-w", "2", "-b", "0.0.0.0:8501", "ui.app:app"]
